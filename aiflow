#!/usr/bin/env python3
"""
aiflow — AI Workflow Runner
Run YAML-defined AI pipelines with any model via OmniRoute
"""

import os
import sys
import json
import yaml
import argparse
import requests
from pathlib import Path
from datetime import datetime

VERSION = "0.1.0"
OMNIROUTE_BASE = os.environ.get("OMNIROUTE_BASE_URL", "http://localhost:3000/v1")
OMNIROUTE_KEY = os.environ.get("OMNIROUTE_API_KEY", "")
DEFAULT_MODEL = os.environ.get("AIFLOW_DEFAULT_MODEL", "auto/best-chat")


def omni_complete(prompt: str, model: str = None, system: str = None) -> str:
    """Send a prompt to OmniRoute and get completion (supports streaming)."""
    url = f"{OMNIROUTE_BASE}/chat/completions"
    model = model or DEFAULT_MODEL

    messages = []
    if system:
        messages.append({"role": "system", "content": system})
    messages.append({"role": "user", "content": prompt})

    headers = {"Content-Type": "application/json"}
    if OMNIROUTE_KEY:
        headers["Authorization"] = f"Bearer {OMNIROUTE_KEY}"

    resp = requests.post(url, headers=headers, json={
        "model": model,
        "messages": messages,
        "temperature": 0.7,
        "max_tokens": 4096,
        "stream": False,
    }, timeout=120)

    if resp.status_code != 200:
        raise RuntimeError(f"OmniRoute error ({resp.status_code}): {resp.text[:300]}")

    # Handle SSE streaming response
    content_type = resp.headers.get("Content-Type", "")
    if "text/event-stream" in content_type:
        # Parse SSE manually
        parts = []
        for line in resp.text.split("\n"):
            line = line.strip()
            if line.startswith("data: ") and line != "data: [DONE]":
                try:
                    chunk = json.loads(line[6:])
                    delta = chunk.get("choices", [{}])[0].get("delta", {})
                    if "content" in delta:
                        parts.append(delta["content"])
                except (json.JSONDecodeError, KeyError, IndexError):
                    continue
        return "".join(parts).strip()
    else:
        # Normal JSON response
        data = resp.json()
        return data["choices"][0]["message"]["content"].strip()


def resolve_variables(text: str, vars: dict) -> str:
    """Replace {{var}} placeholders."""
    for k, v in vars.items():
        text = text.replace("{{" + k + "}}", str(v))
    return text


def load_workflow(path: str) -> dict:
    """Load and validate a workflow YAML file."""
    with open(path) as f:
        wf = yaml.safe_load(f)

    if not wf or "workflow" not in wf:
        raise ValueError("Workflow must have a 'workflow' key")

    steps = wf["workflow"].get("steps", [])
    if not steps:
        raise ValueError("Workflow must have at least one step")

    return wf


def resolve_step_context(step: dict, vars: dict, step_outputs: dict) -> str:
    """Build context for a step from previous step outputs."""
    ctx_parts = []

    # Direct context field
    if "context" in step:
        ctx = step["context"]
        if isinstance(ctx, str):
            if ctx.startswith("file://"):
                fpath = ctx[7:]
                try:
                    with open(Path(fpath).expanduser()) as f:
                        ctx_parts.append(f.read())
                except Exception as e:
                    print(f"  ⚠ Could not read context file {fpath}: {e}")
            else:
                ctx_parts.append(resolve_variables(ctx, vars))
        elif isinstance(ctx, list):
            for item in ctx:
                if isinstance(item, str) and item.startswith("step://"):
                    step_id = item[7:]
                    if step_id in step_outputs:
                        ctx_parts.append(step_outputs[step_id])
                elif isinstance(item, str):
                    ctx_parts.append(resolve_variables(item, vars))
                else:
                    ctx_parts.append(str(item))

    # Auto-include previous step output
    prev_id = step.get("context_from")
    if prev_id and prev_id in step_outputs:
        ctx_parts.append(step_outputs[prev_id])

    return "\n\n".join(ctx_parts) if ctx_parts else None


def run_workflow(wf_path: str, vars: dict):
    """Execute a workflow."""
    wf = load_workflow(wf_path)
    config = wf["workflow"]
    steps = config["steps"]
    step_outputs = {}

    print(f"\n{'='*60}")
    print(f"  🔄 aiflow v{VERSION} — Workflow: {Path(wf_path).name}")
    print(f"  📋 Steps: {len(steps)}")
    if vars:
        print(f"  📌 Variables: {', '.join(f'{k}={v}' for k, v in vars.items())}")
    print(f"{'='*60}\n")

    for i, step in enumerate(steps):
        step_id = step.get("id", f"step-{i+1}")
        model = step.get("model", DEFAULT_MODEL)
        prompt = resolve_variables(step.get("prompt", ""), vars)

        # Handle action steps (fetch, system, etc.)
        action = step.get("action", "llm")

        print(f"  [{i+1}/{len(steps)}] {step_id}")
        print(f"  ├ Model: {model}")

        if action == "llm":
            # Build context from previous steps
            context = resolve_step_context(step, vars, step_outputs)
            full_prompt = prompt
            if context:
                full_prompt = f"Context:\n{context}\n\nTask:\n{prompt}"

            sys_msg = step.get("system")
            preview = full_prompt[:80].replace("\n", " ") + ("..." if len(full_prompt) > 80 else "")
            print(f"  ├ Prompt: {preview}")

            start = datetime.now()
            try:
                result = omni_complete(full_prompt, model, sys_msg)
                elapsed = (datetime.now() - start).total_seconds()
                print(f"  └ ✅ Done ({elapsed:.1f}s, {len(result)} chars)")

                step_outputs[step_id] = result

                # Save if requested
                if "save" in step:
                    save_path = resolve_variables(step["save"], {**vars, **{k: v[:500] for k, v in step_outputs.items()}})
                    save_path = save_path.replace("file://", "")
                    out_path = Path(save_path)
                    out_path.parent.mkdir(parents=True, exist_ok=True)
                    out_path.write_text(result)
                    print(f"     💾 Saved: {out_path}")

            except Exception as e:
                print(f"  └ ❌ Error: {e}")
                if step.get("continue_on_error"):
                    step_outputs[step_id] = f"[ERROR: {e}]"
                    continue
                sys.exit(1)

        elif action == "fetch":
            url = resolve_variables(step.get("url", ""), vars)
            print(f"  ├ Fetch: {url}")
            try:
                resp = requests.get(url, timeout=30, headers={
                    "User-Agent": "aiflow/1.0"
                })
                result = resp.text[:100000]
                step_outputs[step_id] = result
                print(f"  └ ✅ Fetched ({len(result)} chars)")

                if "save" in step:
                    save_path = resolve_variables(step["save"], vars)
                    out_path = Path(save_path)
                    out_path.parent.mkdir(parents=True, exist_ok=True)
                    out_path.write_text(result)
                    print(f"     💾 Saved: {out_path}")
            except Exception as e:
                print(f"  └ ❌ Error: {e}")
                if not step.get("continue_on_error"):
                    sys.exit(1)

        print()

    print(f"{'='*60}")
    print(f"  ✅ Workflow complete! {len(step_outputs)}/{len(steps)} steps successful")
    print(f"{'='*60}\n")


def cmd_run(args):
    """Run a workflow."""
    vars = {}
    if args.var:
        for v in args.var:
            if "=" in v:
                k, val = v.split("=", 1)
                vars[k] = val

    run_workflow(args.workflow, vars)


