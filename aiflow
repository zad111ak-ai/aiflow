#!/usr/bin/env python3
"""
aiflow — AI Workflow Runner
Run YAML-defined AI pipelines with any model via OmniRoute or OpenAI API.

Usage:
  aiflow run workflow.yml
  aiflow run research.yml topic="AI agents"
  aiflow init
  aiflow examples
  aiflow donate
"""

import os
import sys
import json
import yaml
import argparse
import requests
from pathlib import Path
from datetime import datetime

VERSION = "0.1.0"
OMNIROUTE_BASE = os.environ.get("OMNIROUTE_BASE_URL", "http://localhost:3000/v1")
OMNIROUTE_KEY = os.environ.get("OMNIROUTE_API_KEY", "")
OPENAI_BASE = os.environ.get("OPENAI_BASE_URL", "https://api.openai.com/v1")
OPENAI_KEY = os.environ.get("OPENAI_API_KEY", "")
DEFAULT_MODEL = os.environ.get("AIFLOW_DEFAULT_MODEL", "auto/best-chat")


def omni_complete(prompt: str, model: str = None, system: str = None) -> str:
    """Send a prompt and get completion. Supports OmniRoute SSE and OpenAI JSON."""
    model = model or DEFAULT_MODEL

    # Route to OmniRoute or OpenAI
    use_omniroute = not model.startswith("openai/")
    base_url = OMNIROUTE_BASE if use_omniroute else OPENAI_BASE
    api_key = OMNIROUTE_KEY if use_omniroute else OPENAI_KEY
    actual_model = model.replace("openai/", "", 1) if not use_omniroute else model

    url = f"{base_url}/chat/completions"
    messages = []
    if system:
        messages.append({"role": "system", "content": system})
    messages.append({"role": "user", "content": prompt})

    headers = {"Content-Type": "application/json"}
    if api_key:
        headers["Authorization"] = f"Bearer {api_key}"

    payload = {
        "model": actual_model,
        "messages": messages,
        "temperature": 0.7,
        "max_tokens": 4096,
        "stream": False,
    }

    try:
        resp = requests.post(url, headers=headers, json=payload, timeout=120)
    except requests.exceptions.ConnectionError:
        # Fallback: try OpenAI if OmniRoute unavailable and we have an API key
        if use_omniroute and OPENAI_KEY:
            fallback_url = f"{OPENAI_BASE}/chat/completions"
            payload["model"] = model
            resp = requests.post(fallback_url, headers={
                "Content-Type": "application/json",
                "Authorization": f"Bearer {OPENAI_KEY}",
            }, json=payload, timeout=120)
        else:
            raise RuntimeError(f"Cannot connect to {base_url}")

    if resp.status_code != 200:
        raise RuntimeError(f"API error ({resp.status_code}): {resp.text[:300]}")

    raw = resp.content.decode("utf-8", errors="replace")

    # OmniRoute returns SSE even when stream=false
    if raw.strip().startswith("data:"):
        parts = []
        for line in raw.split("\n"):
            line = line.strip()
            if line.startswith("data: ") and line != "data: [DONE]":
                try:
                    chunk = json.loads(line[6:])
                    delta = chunk.get("choices", [{}])[0].get("delta", {})
                    if "content" in delta:
                        parts.append(delta["content"])
                except (json.JSONDecodeError, KeyError, IndexError):
                    continue
        return "".join(parts).strip()

    # Normal JSON response (OpenAI, etc.)
    try:
        data = json.loads(raw)
        return data["choices"][0]["message"]["content"].strip()
    except (json.JSONDecodeError, KeyError, IndexError) as e:
        raise RuntimeError(f"Failed to parse response: {e}\nRaw: {raw[:500]}")


def resolve_variables(text: str, vars: dict) -> str:
    """Replace {{var}} placeholders."""
    if not text:
        return text
    for k, v in vars.items():
        text = text.replace("{{" + k + "}}", str(v))
    return text


def load_workflow(path: str) -> dict:
    """Load and validate a workflow YAML file."""
    with open(path) as f:
        wf = yaml.safe_load(f)

    if not wf or "workflow" not in wf:
        raise ValueError("Workflow must have a 'workflow' key")

    steps = wf["workflow"].get("steps", [])
    if not steps:
        raise ValueError("Workflow must have at least one step")

    return wf


def resolve_step_context(step: dict, vars: dict, step_outputs: dict) -> str:
    """Build context for a step from previous step outputs."""
    ctx_parts = []

    if "context" in step:
        ctx = step["context"]
        if isinstance(ctx, str):
            if ctx.startswith("file://"):
                fpath = ctx[7:]
                try:
                    with open(Path(fpath).expanduser()) as f:
                        ctx_parts.append(f.read())
                except Exception as e:
                    print(f"  ⚠ Could not read {fpath}: {e}")
            elif ctx.startswith("step://"):
                step_id = ctx[7:]
                if step_id in step_outputs:
                    ctx_parts.append(step_outputs[step_id])
            else:
                ctx_parts.append(resolve_variables(ctx, vars))
        elif isinstance(ctx, list):
            for item in ctx:
                if isinstance(item, str):
                    if item.startswith("step://"):
                        sid = item[7:]
                        if sid in step_outputs:
                            ctx_parts.append(step_outputs[sid])
                    elif item.startswith("file://"):
                        fpath = item[7:]
                        try:
                            with open(Path(fpath).expanduser()) as f:
                                ctx_parts.append(f.read())
                        except Exception as e:
                            print(f"  ⚠ Could not read {fpath}: {e}")
                    else:
                        ctx_parts.append(resolve_variables(item, vars))
                else:
                    ctx_parts.append(str(item))

    prev_id = step.get("context_from")
    if prev_id and prev_id in step_outputs:
        ctx_parts.append(step_outputs[prev_id])

    return "\n\n".join(ctx_parts) if ctx_parts else None


def run_workflow(wf_path: str, vars: dict):
    """Execute a workflow."""
    wf = load_workflow(wf_path)
    config = wf["workflow"]
    steps = config["steps"]
    step_outputs = {}

    print(f"\n{'='*60}")
    print(f"  🔄 aiflow v{VERSION} — {Path(wf_path).name}")
    print(f"  📋 {len(steps)} step(s)")
    if vars:
        print(f"  📌 {', '.join(f'{k}={v}' for k, v in vars.items())}")
    print(f"{'='*60}\n")

    for i, step in enumerate(steps):
        step_id = step.get("id", f"step-{i+1}")
        model = step.get("model", DEFAULT_MODEL)
        prompt_text = resolve_variables(step.get("prompt", ""), vars)
        action = step.get("action", "llm")

        print(f"  [{i+1}/{len(steps)}] {step_id}")
        print(f"  ├ Model: {model}")

        if action == "llm":
            context = resolve_step_context(step, vars, step_outputs)
            full_prompt = prompt_text
            if context:
                full_prompt = f"Context:\n{context}\n\nTask:\n{prompt_text}"

            sys_msg = step.get("system")
            preview = full_prompt[:80].replace("\n", " ") + ("..." if len(full_prompt) > 80 else "")
            print(f"  ├ Prompt: {preview}")

            start = datetime.now()
            try:
                result = omni_complete(full_prompt, model, sys_msg)
                elapsed = (datetime.now() - start).total_seconds()
                print(f"  └ ✅ Done ({elapsed:.1f}s, {len(result)} chars)")
                step_outputs[step_id] = result

                save_path = step.get("save")
                if save_path:
                    sp = resolve_variables(save_path, vars)
                    out = Path(sp)
                    out.parent.mkdir(parents=True, exist_ok=True)
                    out.write_text(result)
                    print(f"     💾 Saved: {out}")
            except Exception as e:
                print(f"  └ ❌ Error: {e}")
                if step.get("continue_on_error"):
                    step_outputs[step_id] = f"[ERROR: {e}]"
                    continue
                sys.exit(1)

        elif action == "fetch":
            url = resolve_variables(step.get("url", ""), vars)
            print(f"  ├ Fetch: {url}")
            try:
                resp = requests.get(url, timeout=30, headers={"User-Agent": "aiflow/1.0"})
                content = resp.text[:100000]
                step_outputs[step_id] = content
                print(f"  └ ✅ Fetched ({len(content)} chars)")

                save_path = step.get("save")
                if save_path:
                    sp = resolve_variables(save_path, vars)
                    out = Path(sp)
                    out.parent.mkdir(parents=True, exist_ok=True)
                    out.write_text(content)
                    print(f"     💾 Saved: {out}")
            except Exception as e:
                print(f"  └ ❌ Error: {e}")
                if not step.get("continue_on_error"):
                    sys.exit(1)

        print()

    print(f"{'='*60}")
    print(f"  ✅ Complete! {len(step_outputs)}/{len(steps)} steps successful")
    print(f"{'='*60}\n")


def cmd_run(args):
    """Run a workflow."""
    vars_dict = {}
    if args.var:
        for v in args.var:
            if "=" in v:
                k, val = v.split("=", 1)
                vars_dict[k] = val
    run_workflow(args.workflow, vars_dict)


def cmd_examples(args):
    """Show example workflows."""
    examples_dir = Path(__file__).parent / "examples"
    if not examples_dir.exists():
        print("No examples directory found.")
        return

    for f in sorted(examples_dir.glob("*.yml")):
        print(f"\n  ── {f.stem} ──")
        print(f.read_text())
    print("\n  Run: aiflow run examples/NAME.yml topic=\"your topic\"\n")


