def cmd_init(args):
    """Create a sample workflow.yml."""
    target = Path(args.path or ".")
    wf_file = target / "workflow.yml"
    if wf_file.exists():
        print(f"  ⚠ {wf_file} already exists")
        return

    content = """# aiflow workflow
workflow:
  steps:
    - id: step1
      prompt: "Write about {{topic}}"
      model: auto/best-chat
      save: output/{{topic}}.md
"""
    wf_file.write_text(content)
    print(f"  ✅ Created {wf_file}")
    print(f"  Run: aiflow run workflow.yml topic=\"your topic\"")


def main():
    parser = argparse.ArgumentParser(
        prog="aiflow",
        description="AI Workflow Runner — YAML-powered AI pipelines with any model",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  aiflow run workflow.yml
  aiflow run research.yml topic="AI agents"
  aiflow init
  aiflow examples
  aiflow donate
        """,
    )
    parser.add_argument("--version", action="version", version=f"aiflow v{VERSION}")
    sub = parser.add_subparsers(dest="command")

    p_run = sub.add_parser("run", help="Run a workflow YAML file")
    p_run.add_argument("workflow", help="Path to workflow YAML file")
    p_run.add_argument("-v", "--var", action="append", help="Variables: key=value")

    p_init = sub.add_parser("init", help="Create a sample workflow.yml")
    p_init.add_argument("path", nargs="?", default=".", help="Directory")

    sub.add_parser("examples", help="Show example workflows")
    sub.add_parser("donate", help="Show donation addresses")
    sub.add_parser("version", help="Show version")

    args = parser.parse_args()

    if args.command == "run":
        cmd_run(args)
    elif args.command == "init":
        cmd_init(args)
    elif args.command == "examples":
        cmd_examples(args)
    elif args.command == "donate":
        cmd_donate(args)
    elif args.command == "version":
        cmd_version(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
