# aiflow — AI workflow runner

# Replace with your actual token
OMNIROUTE_BASE_URL=http://localhost:3000/v1

# Uncomment and set if OmniRoute requires auth
# OMNIROUTE_API_KEY=

# Default model to use if step doesn't specify one
AIFLOW_DEFAULT_MODEL=auto/best-chat

# Path to output directory (default: ./output)
# AIFLOW_OUTPUT_DIR=./output
